<?xml version="1.0" encoding="utf-8"?>
<!-- Раскрывающийся вопрос FAQ -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_pool_panel"
    android:layout_marginTop="6dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Заголовок вопроса -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/txtQuestion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Как начать играть?"
            android:textColor="@color/on_background"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semibold" />

        <TextView
            android:id="@+id/txtExpandIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▼"
            android:textColor="@color/on_background_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Ответ (скрыт по умолчанию) -->
    <TextView
        android:id="@+id/txtAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выберите режим игры на главном экране..."
        android:textColor="@color/on_background_secondary"
        android:textSize="13sp"
        android:fontFamily="@font/inter_regular"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone" />

</LinearLayout>
