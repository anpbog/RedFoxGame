<?xml version="1.0" encoding="utf-8"?>
<!-- Экран поддержки -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/support_title"
            android:textColor="@color/on_background"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold" />

        <!-- Telegram -->
        <LinearLayout
            android:id="@+id/btnTelegram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pool_panel"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_telegram"
                android:contentDescription="Telegram" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/telegram_support"
                android:textColor="@color/on_background"
                android:textSize="15sp"
                android:fontFamily="@font/inter_semibold"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Email -->
        <LinearLayout
            android:id="@+id/btnEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pool_panel"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_email"
                android:contentDescription="Email" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email_support"
                android:textColor="@color/on_background"
                android:textSize="15sp"
                android:fontFamily="@font/inter_semibold"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- FAQ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/faq"
            android:textColor="@color/on_background"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="24dp" />

        <!-- FAQ контейнер (вопросы добавляются программно) -->
        <LinearLayout
            android:id="@+id/faqContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <include layout="@layout/item_faq" />

        </LinearLayout>

        <!-- Назад -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back"
            android:textColor="@color/accent_gold"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:padding="12dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</ScrollView>
