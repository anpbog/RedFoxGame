<?xml version="1.0" encoding="utf-8"?>
<!-- Экран восстановления пароля -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <!-- Переключатель языка -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/langSwitcher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/flagRu"
                    android:layout_width="28dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_flag_ru"
                    android:contentDescription="Русский"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <ImageView
                    android:id="@+id/flagEn"
                    android:layout_width="28dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_flag_en"
                    android:contentDescription="English"
                    android:alpha="0.4"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </FrameLayout>

        <!-- Логотип -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="@string/app_name"
            android:layout_marginTop="24dp" />

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reset_password_title"
            android:textColor="@color/on_background"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="16dp" />

        <!-- Поле Email -->
        <EditText
            android:id="@+id/inputEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/email_hint"
            android:textColor="@color/on_background"
            android:textColorHint="@color/on_background_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:background="@drawable/bg_edit_text"
            android:inputType="textEmailAddress"
            android:layout_marginTop="32dp" />

        <!-- Кнопка Отправить ссылку -->
        <TextView
            android:id="@+id/btnResetPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_password_button"
            android:textColor="@color/on_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_semibold"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Пружина -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Ссылка «Назад» -->
        <TextView
            android:id="@+id/linkBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back"
            android:textColor="@color/accent_gold"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</ScrollView>
