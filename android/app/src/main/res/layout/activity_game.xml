<?xml version="1.0" encoding="utf-8"?>
<!-- Игровой экран — основной -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ============================================ -->
    <!-- 4.1 ВЕРХНЯЯ ПАНЕЛЬ                          -->
    <!-- ============================================ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Баланс -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/balance"
                android:textColor="@color/on_background_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:id="@+id/txtBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$1,000.00"
                android:textColor="@color/on_background"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold" />

        </LinearLayout>

        <!-- Кнопки Пополнить / Вывести -->
        <TextView
            android:id="@+id/btnDeposit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/deposit"
            android:textColor="@color/primary_green"
            android:textSize="12sp"
            android:fontFamily="@font/inter_semibold"
            android:background="@drawable/bg_card_green"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnWithdraw"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/withdraw"
            android:textColor="@color/on_background_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/inter_semibold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Флаг языка -->
        <ImageView
            android:id="@+id/flagLang"
            android:layout_width="24dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_flag_ru"
            android:contentDescription="Язык"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Строка таймера и потенциального дохода -->
    <LinearLayout
        android:id="@+id/timerRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <!-- Потенциальный доход UP -->
        <TextView
            android:id="@+id/txtIncomeUp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="UP +85%"
            android:textColor="@color/primary_green"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_semibold" />

        <!-- Таймер круглый -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_timer_circle" />

            <TextView
                android:id="@+id/txtTimer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="30"
                android:textColor="@color/accent_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold" />

        </FrameLayout>

        <!-- Потенциальный доход DOWN -->
        <TextView
            android:id="@+id/txtIncomeDown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DOWN +92%"
            android:textColor="@color/error_red"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_semibold"
            android:gravity="end" />

    </LinearLayout>

    <!-- ============================================ -->
    <!-- 4.2 ГРАФИК BTC LIVE                         -->
    <!-- ============================================ -->
    <FrameLayout
        android:id="@+id/chartContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_chart_area">

        <!-- Плейсхолдер — здесь будет Canvas/CustomView для графика -->
        <!-- Зелёная зона UP (верхняя полупрозрачная) рисуется программно -->
        <!-- Красная зона DOWN (нижняя полупрозрачная) рисуется программно -->
        <!-- Жёлтая линия цены рисуется программно -->

        <!-- Плашка BTC Live — правый верхний угол -->
        <LinearLayout
            android:id="@+id/btcLiveLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|top"
            android:layout_margin="8dp"
            android:background="@color/surface"
            android:padding="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_btc_coin"
                android:contentDescription="BTC" />

            <TextView
                android:id="@+id/txtBtcPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BTC $67,432.15"
                android:textColor="@color/accent_gold"
                android:textSize="11sp"
                android:fontFamily="@font/orbitron_bold"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ============================================ -->
    <!-- 4.3 ЛЕНТА ИСТОРИИ РАУНДОВ                   -->
    <!-- ============================================ -->
    <HorizontalScrollView
        android:id="@+id/roundHistoryScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/roundHistoryContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!-- Карточки истории добавляются программно -->
            <!-- Пример одной карточки: -->
            <include layout="@layout/item_round_history" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- ============================================ -->
    <!-- 4.4 ПАНЕЛЬ ПУЛОВ                            -->
    <!-- ============================================ -->
    <LinearLayout
        android:id="@+id/poolPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_pool_panel"
        android:padding="8dp">

        <!-- POOL UP (левая часть) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POOL UP"
                android:textColor="@color/primary_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_semibold" />

            <TextView
                android:id="@+id/txtPoolUpPayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payout: 1.85x"
                android:textColor="@color/primary_green"
                android:textSize="11sp"
                android:fontFamily="@font/inter_regular"
                android:layout_marginTop="2dp" />

            <!-- Аватары игроков (добавляются программно) -->
            <LinearLayout
                android:id="@+id/poolUpAvatars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtPoolUpCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 игроков"
                android:textColor="@color/on_background_secondary"
                android:textSize="10sp"
                android:fontFamily="@font/inter_regular"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Разделитель -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/surface_variant"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <!-- POOL DOWN (правая часть) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POOL DOWN"
                android:textColor="@color/error_red"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_semibold" />

            <TextView
                android:id="@+id/txtPoolDownPayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payout: 1.92x"
                android:textColor="@color/error_red"
                android:textSize="11sp"
                android:fontFamily="@font/inter_regular"
                android:layout_marginTop="2dp" />

            <!-- Аватары игроков -->
            <LinearLayout
                android:id="@+id/poolDownAvatars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="end"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtPoolDownCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8 игроков"
                android:textColor="@color/on_background_secondary"
                android:textSize="10sp"
                android:fontFamily="@font/inter_regular"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ============================================ -->
    <!-- 4.5 ПАНЕЛЬ СТАВКИ                           -->
    <!-- ============================================ -->
    <LinearLayout
        android:id="@+id/betPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="4dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <!-- Регулятор суммы: MIN | − | сумма | + | MAX -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_bet_regulator"
            android:padding="4dp">

            <TextView
                android:id="@+id/btnBetMin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/min_bet"
                android:textColor="@color/accent_gold"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_semibold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnBetMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="−"
                android:textColor="@color/on_background"
                android:textSize="20sp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Поле суммы -->
            <EditText
                android:id="@+id/inputBetAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$10.00"
                android:textColor="@color/on_background"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:gravity="center"
                android:background="@null"
                android:inputType="numberDecimal" />

            <TextView
                android:id="@+id/btnBetPlus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="@color/on_background"
                android:textSize="20sp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnBetMax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/max_bet"
                android:textColor="@color/accent_gold"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_semibold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Кнопки UP / DOWN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <!-- Кнопка UP -->
            <LinearLayout
                android:id="@+id/btnUp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_button_up"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_up"
                    android:contentDescription="UP" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pool_up"
                    android:textColor="@color/on_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_semibold"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

            <!-- Кнопка DOWN -->
            <LinearLayout
                android:id="@+id/btnDown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_button_down"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginStart="4dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_down"
                    android:contentDescription="DOWN" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pool_down"
                    android:textColor="@color/on_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_semibold"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
