<?xml version="1.0" encoding="utf-8"?>
<!-- Экран вывода средств -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/withdraw_title"
            android:textColor="@color/on_background"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold" />

        <!-- Плашка KYC (если не пройдена) -->
        <LinearLayout
            android:id="@+id/kycBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_gold"
            android:padding="12dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/kyc_required"
                android:textColor="@color/accent_gold"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold" />

            <TextView
                android:id="@+id/btnKycVerify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Пройти"
                android:textColor="@color/on_primary"
                android:textSize="12sp"
                android:fontFamily="@font/inter_semibold"
                android:background="@drawable/bg_button_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Выбор сети -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:id="@+id/btnNetworkUsdt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_network_button"
                android:padding="12dp"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_usdt"
                    android:contentDescription="USDT" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USDT\nTRC-20"
                    android:textColor="@color/on_background"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_semibold"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnNetworkBtc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_network_button"
                android:padding="12dp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_btc"
                    android:contentDescription="Bitcoin" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bitcoin"
                    android:textColor="@color/on_background"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_semibold"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnNetworkEth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_network_button"
                android:padding="12dp"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_eth"
                    android:contentDescription="Ethereum" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ethereum"
                    android:textColor="@color/on_background"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_semibold"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Адрес получателя + сканер QR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <EditText
                android:id="@+id/inputAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/enter_address"
                android:textColor="@color/on_background"
                android:textColorHint="@color/on_background_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:background="@drawable/bg_edit_text"
                android:inputType="text"
                android:singleLine="true" />

            <ImageView
                android:id="@+id/btnScanQr"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_scan_qr"
                android:padding="10dp"
                android:contentDescription="@string/scan_qr"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_edit_text"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Сумма вывода -->
        <EditText
            android:id="@+id/inputAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/amount"
            android:textColor="@color/on_background"
            android:textColorHint="@color/on_background_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:background="@drawable/bg_edit_text"
            android:inputType="numberDecimal"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Минимум: $10"
            android:textColor="@color/on_background_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"
            android:layout_marginTop="4dp" />

        <!-- Комиссия -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/commission"
                android:textColor="@color/on_background_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:id="@+id/txtCommission"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$1.00"
                android:textColor="@color/on_background"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold" />

        </LinearLayout>

        <!-- Кнопка подтвердить -->
        <TextView
            android:id="@+id/btnConfirmWithdraw"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/confirm"
            android:textColor="@color/on_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_semibold"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Назад -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back"
            android:textColor="@color/accent_gold"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:padding="12dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</ScrollView>
